{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/api-zod exec tsc --build && pnpm --filter @workspace/xito-tracker run build",
  "outputDirectory": "artifacts/xito-tracker/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
