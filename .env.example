# ============================================================
# XITO TRACKER — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in your actual values.
# Find secret values in Replit → Secrets panel (lock icon).
# NEVER commit .env with real values to version control.
# ============================================================


# ────────────────────────────────────────────────────────────
# SUPABASE
# Project: https://supabase.com/dashboard/project/trbgmgnxifqrdpequuxq
# ────────────────────────────────────────────────────────────

# Your Supabase project URL (non-secret, safe to share)
SUPABASE_URL=https://trbgmgnxifqrdpequuxq.supabase.co

# Same URL exposed to the frontend (Vite bundles VITE_ vars into the browser)
VITE_SUPABASE_URL=https://trbgmgnxifqrdpequuxq.supabase.co

# Supabase connection string for direct DB access (Secrets panel → SUPABASE_DATABASE_URL)
SUPABASE_DATABASE_URL=postgresql://postgres.trbgmgnxifqrdpequuxq:<DB_PASSWORD>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Supabase DB password (Secrets panel → SUPABASE_DB_PASSWORD)
SUPABASE_DB_PASSWORD=your_supabase_db_password_here

# Supabase anon/public key — used server-side (Secrets panel → SUPABASE_ANON_KEY)
# Found in: Supabase Dashboard → Project Settings → API → Project API Keys → anon/public
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase anon key exposed to the frontend (Secrets panel → VITE_SUPABASE_ANON_KEY)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key — NEVER expose to frontend (Secrets panel → SUPABASE_SERVICE_ROLE_KEY)
# Found in: Supabase Dashboard → Project Settings → API → Project API Keys → service_role
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here


# ────────────────────────────────────────────────────────────
# CLERK AUTH
# Managed via: Replit Auth pane (workspace toolbar)
# ────────────────────────────────────────────────────────────

# Clerk publishable key — used by the API server (Secrets panel → CLERK_PUBLISHABLE_KEY)
# Starts with pk_test_ (dev) or pk_live_ (production)
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Clerk secret key — server-side only, NEVER expose (Secrets panel → CLERK_SECRET_KEY)
# Starts with sk_test_ (dev) or sk_live_ (production)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Clerk publishable key exposed to the frontend (Secrets panel → VITE_CLERK_PUBLISHABLE_KEY)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Clerk proxy URL — only needed if using a custom domain (optional)
# Example: https://yourdomain.com/api/__clerk
VITE_CLERK_PROXY_URL=


# ────────────────────────────────────────────────────────────
# SESSION / SECURITY
# ────────────────────────────────────────────────────────────

# Random secret for signing sessions — generate with: openssl rand -hex 32
# (Secrets panel → SESSION_SECRET)
SESSION_SECRET=your_random_session_secret_here


# ────────────────────────────────────────────────────────────
# SERVER CONFIG
# ────────────────────────────────────────────────────────────

# Port the API server listens on (set by hosting platform, usually 8080)
PORT=8080

# Environment: development | production
NODE_ENV=production

# Log level: trace | debug | info | warn | error (optional, defaults to info)
LOG_LEVEL=info


# ────────────────────────────────────────────────────────────
# REPLIT RUNTIME (auto-set by Replit, do not change)
# These are injected automatically in both dev and production.
# ────────────────────────────────────────────────────────────

# REPLIT_DOMAINS=your-app.replit.app       (comma-separated public domains)
# REPLIT_DEV_DOMAIN=your-dev-domain        (dev preview domain)
# REPL_ID=your-repl-id                     (unique repl identifier)
# DATABASE_URL=postgres://...              (Replit-managed Postgres, if used)
